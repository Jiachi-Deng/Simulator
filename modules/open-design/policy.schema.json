{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "open-design-artifact-policy-v1", "type": "object",
  "required": ["schemaVersion", "profile", "description", "limits", "pathRules", "exactPathRules", "requiredFiles", "forbiddenSegmentPatterns", "forbiddenBasenamePatterns", "allowedDependencyScopes", "sbomRequirements", "resourceCategories", "resourceExtensions", "resourcePathCategories", "nativeBinaryExtensions"],
  "properties": {
    "schemaVersion": {"const": 1}, "profile": {"const": "next-standalone-plus-daemon-runtime"}, "description": {"type": "string", "minLength": 1, "maxLength": 1024},
    "limits": {"type": "object", "required": ["maxEntries", "maxPathBytes", "maxStringBytes", "maxFileBytes", "maxTotalBytes"], "properties": {"maxEntries": {"type": "integer", "minimum": 1}, "maxPathBytes": {"type": "integer", "minimum": 1}, "maxStringBytes": {"type": "integer", "minimum": 1}, "maxFileBytes": {"type": "integer", "minimum": 1}, "maxTotalBytes": {"type": "integer", "minimum": 1}}, "additionalProperties": false},
    "pathRules": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"type": "object", "required": ["prefix", "artifactKind", "components"], "properties": {"prefix": {"type": "string", "minLength": 1, "maxLength": 1024}, "artifactKind": {"enum": ["web-server", "web-static", "daemon-runtime", "runtime-package", "legal", "metadata", "native-binary", "executable-native", "wasm-resource"]}, "components": {"type": "array", "minItems": 1, "maxItems": 16, "items": {"enum": ["next-standalone", "next-static", "next-public", "daemon", "runtime-package", "legal", "metadata"]}}}, "additionalProperties": false}},
    "exactPathRules": {"type": "array", "maxItems": 32, "items": {"type": "object", "required": ["path", "artifactKind", "component"], "properties": {"path": {"type": "string", "minLength": 1, "maxLength": 1024}, "artifactKind": {"enum": ["metadata"]}, "component": {"enum": ["metadata"]}}, "additionalProperties": false}},
    "requiredFiles": {"type": "array", "minItems": 4, "maxItems": 16, "items": {"type": "object", "required": ["path", "artifactKind", "component", "mediaType", "schemaId"], "properties": {"path": {"type": "string", "minLength": 1, "maxLength": 1024}, "artifactKind": {"enum": ["legal", "metadata"]}, "component": {"enum": ["legal", "metadata"]}, "mediaType": {"type": "string", "minLength": 1, "maxLength": 128}, "schemaId": {"type": "string", "minLength": 1, "maxLength": 128}, "schemaVersion": {"type": ["integer", "string"], "minimum": 1, "maxLength": 64}}, "additionalProperties": false}},
    "forbiddenSegmentPatterns": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"type": "string", "minLength": 1, "maxLength": 128}},
    "forbiddenBasenamePatterns": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"type": "string", "minLength": 1, "maxLength": 128}},
    "allowedDependencyScopes": {"type": "array", "minItems": 1, "maxItems": 8, "items": {"enum": ["production", "artifact"]}},
    "sbomRequirements": {"type": "object", "required": ["requireExactPackageSet", "requireLockResolution", "requireContentChecksum", "requireLicenseDeclared", "requireNoticeStatus"], "properties": {"requireExactPackageSet": {"const": true}, "requireLockResolution": {"const": true}, "requireContentChecksum": {"const": true}, "requireLicenseDeclared": {"const": true}, "requireNoticeStatus": {"const": true}}, "additionalProperties": false},
    "resourceCategories": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"enum": ["templates", "fonts", "images", "plugins", "skills", "native-binaries"]}},
    "resourceExtensions": {"type": "object", "required": ["fonts", "images"], "properties": {"fonts": {"type": "array", "minItems": 1, "maxItems": 16, "items": {"type": "string", "minLength": 2, "maxLength": 16}}, "images": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"type": "string", "minLength": 2, "maxLength": 16}}}, "additionalProperties": false},
    "resourcePathCategories": {"type": "object", "required": ["plugins", "skills", "templates", "design-templates", "design-systems", "assets"], "properties": {"plugins": {"const": "plugins"}, "skills": {"const": "skills"}, "templates": {"const": "templates"}, "design-templates": {"const": "templates"}, "design-systems": {"type": "null"}, "assets": {"type": "null"}}, "additionalProperties": false},
    "nativeBinaryExtensions": {"type": "array", "minItems": 1, "maxItems": 16, "items": {"enum": [".node", ".so", ".dylib", ".dll", ".exe"]}}
  }, "additionalProperties": false
}
