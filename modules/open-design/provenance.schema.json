{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "open-design-provenance-v1", "type": "object",
  "required": ["schemaVersion", "repository", "source", "license", "upstreamManifest", "simulatorPatch", "lockfile", "sbom", "buildInputs", "buildToolchainExpectations", "buildContract"],
  "properties": {
    "schemaVersion": {"const": 1},
    "repository": {"const": "https://github.com/nexu-io/open-design"},
    "source": {"type": "object", "required": ["refType", "ref", "commit", "sourceDate", "observedHead", "auditedAt"], "properties": {
      "refType": {"enum": ["tag", "commit"]}, "ref": {"type": "string", "minLength": 1, "maxLength": 256},
      "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "sourceDate": {"type": "string", "minLength": 1, "maxLength": 64},
      "observedHead": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "auditedAt": {"type": "string", "minLength": 1, "maxLength": 64}
    }, "additionalProperties": false},
    "license": {"type": "object", "required": ["spdxId", "sourceFile"], "properties": {"spdxId": {"const": "Apache-2.0"}, "sourceFile": {"const": "LICENSE"}}, "additionalProperties": false},
    "upstreamManifest": {"type": "object", "required": ["path", "name", "version", "packageManager", "sha256"], "properties": {"path": {"const": "package.json"}, "name": {"const": "open-design"}, "version": {"type": "string", "minLength": 1, "maxLength": 64}, "packageManager": {"const": "pnpm@10.33.2"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}, "additionalProperties": false},
    "simulatorPatch": {"type": "object", "required": ["path", "sha256", "preimageSha256", "postimageSha256", "changedPaths", "fileDigests", "purpose"], "properties": {
      "path": {"const": "patches/open-design-v0.14.1-simulator-host-runtime.patch"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "preimageSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "postimageSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "changedPaths": {"type": "array", "minItems": 22, "maxItems": 22, "uniqueItems": true, "items": {"enum": ["apps/daemon/src/routes/runs.ts", "apps/daemon/src/routes/static-resource.ts", "apps/daemon/src/routes/vela.ts", "apps/daemon/src/runtimes/defs/simulator-host.ts", "apps/daemon/src/runtimes/registry.ts", "apps/daemon/src/runtimes/runs.ts", "apps/daemon/src/server.ts", "apps/daemon/src/simulator-host-agent.ts", "apps/web/next.config.ts", "apps/web/src/App.tsx", "apps/web/src/components/AvatarMenu.tsx", "apps/web/src/components/EntrySettingsMenu.tsx", "apps/web/src/components/EntryShell.tsx", "apps/web/src/components/FileWorkspace.tsx", "apps/web/src/components/InlineModelSwitcher.tsx", "apps/web/src/components/ProjectView.tsx", "apps/web/src/components/SettingsDialog.tsx", "apps/web/src/index.css", "apps/web/src/providers/daemon.ts", "apps/web/src/providers/simulator-host-mode.js", "apps/web/src/styles/simulator-host.css", "package.json"]}},
      "fileDigests": {"type": "array", "minItems": 22, "maxItems": 22, "items": {"type": "object", "required": ["path", "preimageSha256", "postimageSha256"], "properties": {
        "path": {"enum": ["apps/daemon/src/routes/runs.ts", "apps/daemon/src/routes/static-resource.ts", "apps/daemon/src/routes/vela.ts", "apps/daemon/src/runtimes/defs/simulator-host.ts", "apps/daemon/src/runtimes/registry.ts", "apps/daemon/src/runtimes/runs.ts", "apps/daemon/src/server.ts", "apps/daemon/src/simulator-host-agent.ts", "apps/web/next.config.ts", "apps/web/src/App.tsx", "apps/web/src/components/AvatarMenu.tsx", "apps/web/src/components/EntrySettingsMenu.tsx", "apps/web/src/components/EntryShell.tsx", "apps/web/src/components/FileWorkspace.tsx", "apps/web/src/components/InlineModelSwitcher.tsx", "apps/web/src/components/ProjectView.tsx", "apps/web/src/components/SettingsDialog.tsx", "apps/web/src/index.css", "apps/web/src/providers/daemon.ts", "apps/web/src/providers/simulator-host-mode.js", "apps/web/src/styles/simulator-host.css", "package.json"]},
        "preimageSha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}, "postimageSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }, "additionalProperties": false}},
      "purpose": {"type": "string", "minLength": 1, "maxLength": 512}
    }, "additionalProperties": false},
    "lockfile": {"type": "object", "required": ["path", "sha256"], "properties": {"path": {"const": "pnpm-lock.yaml"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}, "additionalProperties": false},
    "sbom": {"type": "object", "required": ["requiredPackages"], "properties": {"requiredPackages": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"type": "object", "required": ["name", "version", "contentSha512", "licenseDeclared", "noticeStatus"], "properties": {
      "name": {"type": "string", "minLength": 1, "maxLength": 128}, "version": {"type": "string", "minLength": 1, "maxLength": 64}, "contentSha512": {"type": "string", "pattern": "^[0-9a-f]{128}$"}, "licenseDeclared": {"type": "string", "minLength": 1, "maxLength": 128}, "noticeStatus": {"enum": ["NONE", "PRESENT"]}
    }, "additionalProperties": false}}}, "additionalProperties": false},
    "buildInputs": {"type": "array", "minItems": 5, "maxItems": 16, "items": {"type": "object", "required": ["path", "sha256"], "properties": {"path": {"type": "string", "minLength": 1, "maxLength": 256}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}, "additionalProperties": false}},
    "buildToolchainExpectations": {"type": "object", "required": ["node", "nodeAbi", "platform", "arch", "nodeDistributionUrl", "nodeDistributionSha256", "nodeExecutableSha256", "pnpm", "pnpmPackageIntegrity", "pnpmExecutableSha256", "typescript", "next", "artifactTargets", "reproducibility"], "properties": {
      "node": {"const": "24.18.0"}, "nodeAbi": {"const": "137"}, "platform": {"const": "darwin"}, "arch": {"const": "arm64"},
      "nodeDistributionUrl": {"const": "https://nodejs.org/dist/v24.18.0/node-v24.18.0-darwin-arm64.tar.gz"},
      "nodeDistributionSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "nodeExecutableSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "pnpm": {"const": "10.33.2"}, "pnpmPackageIntegrity": {"type": "string", "pattern": "^sha512-[0-9a-f]{128}$"}, "pnpmExecutableSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "typescript": {"type": "string", "minLength": 1, "maxLength": 256}, "next": {"type": "string", "minLength": 1, "maxLength": 64},
      "artifactTargets": {"type": "array", "minItems": 1, "maxItems": 16, "items": {"type": "string", "minLength": 1, "maxLength": 256}},
      "reproducibility": {"type": "string", "minLength": 1, "maxLength": 1024}
    }, "additionalProperties": false},
    "buildContract": {"type": "object", "required": ["environmentPolicy", "commands"], "properties": {
      "environmentPolicy": {"type": "object", "required": ["inherit", "force"], "properties": {
        "inherit": {"type": "array", "minItems": 0, "maxItems": 0, "items": {"type": "string", "minLength": 1, "maxLength": 64}},
        "force": {"type": "object", "additionalProperties": {"type": "string"}}
      }, "additionalProperties": false},
      "commands": {"type": "array", "minItems": 6, "maxItems": 32, "items": {"type": "string", "minLength": 1, "maxLength": 512}}
    }, "additionalProperties": false}
  }, "additionalProperties": false
}
