{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "open-design-artifact-inventory-file-v1", "type": "object",
  "required": ["schemaVersion", "path", "type", "artifactKind", "component", "dependencyScope", "bytes", "sha256"],
  "properties": {
    "schemaVersion": {"const": 1},
    "path": {"type": "string", "minLength": 1, "maxLength": 1024},
    "type": {"enum": ["file", "symlink"]},
    "artifactKind": {"enum": ["web-server", "web-static", "daemon-runtime", "runtime-package", "legal", "metadata", "native-binary"]},
    "component": {"enum": ["next-standalone", "next-static", "next-public", "daemon", "runtime-package", "legal", "metadata"]},
    "dependencyScope": {"enum": ["production", "artifact", "development"]},
    "bytes": {"type": "integer", "minimum": 0},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "symlinkTarget": {"type": "string", "minLength": 1, "maxLength": 1024},
    "mediaType": {"type": "string", "minLength": 1, "maxLength": 128},
    "schemaId": {"type": "string", "minLength": 1, "maxLength": 128},
    "contentSchemaVersion": {"type": ["integer", "string"], "minimum": 1, "maxLength": 64},
    "sourceCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sourcePath": {"type": "string", "minLength": 1, "maxLength": 1024},
    "resourceCategory": {"enum": ["templates", "fonts", "images", "plugins", "skills", "native-binaries"]},
    "decisionId": {"type": "string", "minLength": 1, "maxLength": 128},
    "nativeTarget": {
      "type": "object", "required": ["format", "platform", "arch", "libc"],
      "properties": {
        "format": {"enum": ["node-addon", "executable", "shared-library"]},
        "platform": {"enum": ["darwin", "linux", "win32"]},
        "arch": {"enum": ["arm64", "x64"]},
        "libc": {"enum": ["none", "glibc", "musl", "msvcrt"]},
        "nodeAbi": {"type": "string", "pattern": "^[0-9]{1,4}$"}
      }, "additionalProperties": false
    }
  }, "additionalProperties": false
}
