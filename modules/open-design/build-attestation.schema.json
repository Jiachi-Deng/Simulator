{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "open-design-build-attestation-v1",
  "type": "object",
  "required": ["schemaVersion", "distribution", "sourceCommit", "patch", "toolchain", "environment", "inputs", "sbom", "resourceMetadata", "commands", "build", "native", "runtimeVerification"],
  "properties": {
    "schemaVersion": {"const": 1},
    "distribution": {"type": "object", "required": ["class", "nonPromotable"], "properties": {"class": {"enum": ["public", "development-local-only"]}, "nonPromotable": {"type": "boolean"}}, "additionalProperties": false},
    "sourceCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "patch": {"type": "object", "required": ["path", "sha256", "postimageSha256", "changedPaths"], "properties": {
      "path": {"type": "string", "minLength": 1, "maxLength": 256},
      "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "postimageSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "changedPaths": {"type": "array", "minItems": 23, "maxItems": 23, "uniqueItems": true, "items": {"enum": ["apps/daemon/src/routes/runs.ts", "apps/daemon/src/routes/static-resource.ts", "apps/daemon/src/routes/vela.ts", "apps/daemon/src/runtimes/defs/simulator-host.ts", "apps/daemon/src/runtimes/json-event-stream.ts", "apps/daemon/src/runtimes/registry.ts", "apps/daemon/src/runtimes/simulator-host-v2-event-stream.ts", "apps/daemon/src/server.ts", "apps/daemon/src/simulator-host-agent.ts", "apps/web/next.config.ts", "apps/web/src/App.tsx", "apps/web/src/components/AvatarMenu.tsx", "apps/web/src/components/EntrySettingsMenu.tsx", "apps/web/src/components/EntryShell.tsx", "apps/web/src/components/FileWorkspace.tsx", "apps/web/src/components/InlineModelSwitcher.tsx", "apps/web/src/components/ProjectView.tsx", "apps/web/src/components/SettingsDialog.tsx", "apps/web/src/index.css", "apps/web/src/providers/daemon.ts", "apps/web/src/providers/simulator-host-mode.js", "apps/web/src/styles/simulator-host.css", "package.json"]}}
    }, "additionalProperties": false},
    "toolchain": {"type": "object", "required": ["nodeVersion", "nodeAbi", "platform", "arch", "nodeExecutableSha256", "pnpmVersion", "pnpmExecutableSha256"], "properties": {
      "nodeVersion": {"const": "24.18.0"}, "nodeAbi": {"const": "137"}, "platform": {"const": "darwin"}, "arch": {"const": "arm64"},
      "nodeExecutableSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "pnpmVersion": {"const": "10.33.2"}, "pnpmExecutableSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    }, "additionalProperties": false},
    "environment": {"type": "object", "required": ["CI", "COREPACK_ENABLE_DOWNLOAD_PROMPT", "HOME", "OD_WEB_OUTPUT_MODE", "PATH", "TMPDIR", "XDG_CACHE_HOME", "npm_config_cache", "npm_config_store_dir", "npm_config_update_notifier"], "properties": {
      "CI": {"const": "1"}, "COREPACK_ENABLE_DOWNLOAD_PROMPT": {"const": "0"}, "HOME": {"const": "<private-home>"},
      "OD_WEB_OUTPUT_MODE": {"const": "standalone"}, "PATH": {"const": "<node-dir>:/usr/bin:/bin"}, "TMPDIR": {"const": "<private-tmp>/"},
      "XDG_CACHE_HOME": {"const": "<private-cache>"}, "npm_config_cache": {"const": "<private-cache>/npm"},
      "npm_config_store_dir": {"const": "<private-store>"}, "npm_config_update_notifier": {"const": "false"}
    }, "additionalProperties": false},
    "inputs": {"type": "array", "minItems": 9, "maxItems": 64, "items": {"type": "object", "required": ["name", "sha256"], "properties": {
      "name": {"type": "string", "minLength": 1, "maxLength": 256}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    }, "additionalProperties": false}},
    "sbom": {"type": "object", "required": ["documentSha256", "lockfileSha256", "packages"], "properties": {
      "documentSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "lockfileSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "packages": {"type": "array", "minItems": 5, "maxItems": 5, "items": {"type": "object", "required": ["name", "version", "contentSha512", "licenseDeclared", "noticeStatus"], "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 128}, "version": {"type": "string", "minLength": 1, "maxLength": 64}, "contentSha512": {"type": "string", "pattern": "^[0-9a-f]{128}$"}, "licenseDeclared": {"type": "string", "minLength": 1, "maxLength": 128}, "noticeStatus": {"enum": ["NONE", "PRESENT"]}
      }, "additionalProperties": false}}
    }, "additionalProperties": false},
    "resourceMetadata": {"type": "object", "required": ["documentSha256", "resourceCount", "categories"], "properties": {
      "documentSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "resourceCount": {"type": "integer", "minimum": 0},
      "categories": {"type": "object"}
    }, "additionalProperties": false},
    "commands": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"type": "object", "required": ["ordinal", "executable", "executableSha256", "args", "cwdRole", "environmentSha256"], "properties": {
      "ordinal": {"type": "integer", "minimum": 0}, "executable": {"const": "<node>"}, "executableSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "args": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"type": "string", "maxLength": 4096}}, "cwdRole": {"const": "private-detached-checkout"},
      "environmentSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    }, "additionalProperties": false}},
    "build": {"type": "object", "required": ["privateDetachedCheckout", "postBuildVerified", "freshOutputs", "normalization"], "properties": {
      "privateDetachedCheckout": {"const": true}, "postBuildVerified": {"const": true}, "freshOutputs": {"type": "array", "minItems": 4, "maxItems": 16, "items": {"type": "string", "minLength": 1, "maxLength": 256}},
      "normalization": {"type": "object", "required": ["method", "artifactSymlinksForbidden", "outputs", "nativeOrigins", "daemonClosure"], "properties": {
        "method": {"const": "daemon-esm-bundle-external-closure-v1"}, "artifactSymlinksForbidden": {"const": true},
        "outputs": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "object", "required": ["role", "symlinksMaterialized", "hardlinksMaterialized", "virtualStorePackagesHoisted"], "properties": {
          "role": {"enum": ["next-standalone", "daemon-esm-bundle-external-closure", "web-sidecar-closure"]}, "symlinksMaterialized": {"type": "integer", "minimum": 0}, "hardlinksMaterialized": {"type": "integer", "minimum": 0}, "virtualStorePackagesHoisted": {"type": "integer", "minimum": 0}
        }, "additionalProperties": false}},
        "nativeOrigins": {"type": "array", "maxItems": 10000, "items": {"type": "object", "required": ["path", "sha256", "freshFromBuild", "mode"], "properties": {
          "path": {"type": "string", "minLength": 1, "maxLength": 1024}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "freshFromBuild": {"const": true}, "mode": {"enum": ["0644", "0755"]}
        }, "additionalProperties": false}},
        "daemonClosure": {"type": "object", "required": ["method", "bundleSha256", "metafileSha256", "metafileInputCount", "metafileOutput", "externalAllowlist", "files"], "properties": {
          "method": {"const": "esbuild-node24-esm-create-require-banner-v1"}, "bundleSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "metafileSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "metafileInputCount": {"type": "integer", "minimum": 1}, "metafileOutput": {"const": "runtime/daemon/dist/sidecar/index.js"},
          "externalAllowlist": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"enum": ["better-sqlite3", "node-pty", "blake3-wasm"]}},
          "files": {"type": "array", "minItems": 1, "maxItems": 1000, "items": {"type": "object", "required": ["path", "sha256"], "properties": {"path": {"type": "string", "pattern": "^runtime/daemon/", "maxLength": 1024}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}, "additionalProperties": false}}
        }, "additionalProperties": false}
      }, "additionalProperties": false}
    }, "additionalProperties": false},
    "native": {"type": "array", "maxItems": 10000, "items": {"type": "object", "required": ["packageName", "path", "format", "platform", "arch", "nodeAbi", "libc", "binaryFormat", "resourceClass", "mode", "sha256", "freshFromBuild", "load"], "properties": {
      "packageName": {"enum": ["better-sqlite3", "node-pty", "sharp", "blake3-wasm"]}, "path": {"type": "string", "minLength": 1, "maxLength": 1024}, "format": {"enum": ["node-addon", "executable", "shared-library", "wasm-module"]},
      "platform": {"const": "darwin"}, "arch": {"const": "arm64"}, "nodeAbi": {"const": "137"}, "libc": {"const": "none"}, "binaryFormat": {"enum": ["mach-o", "wasm"]}, "resourceClass": {"enum": ["native-binary", "executable-native", "wasm-resource"]}, "mode": {"enum": ["0644", "0755"]},
      "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "freshFromBuild": {"const": true},
      "load": {"type": ["object", "null"], "required": ["ok", "nodeVersion", "nodeAbi", "platform", "arch"], "properties": {"ok": {"const": true}, "nodeVersion": {"const": "v24.18.0"}, "nodeAbi": {"const": "137"}, "platform": {"const": "darwin"}, "arch": {"const": "arm64"}}, "additionalProperties": false}
    }, "additionalProperties": false}},
    "runtimeVerification": {"type": "object", "required": ["method", "candidateMustBeSealed", "entries", "expected"], "properties": {
      "method": {"const": "sealed-candidate-loopback-v1"}, "candidateMustBeSealed": {"const": true},
      "entries": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "object", "required": ["entryPath", "entrySha256"], "properties": {"entryPath": {"type": "string", "minLength": 1, "maxLength": 1024}, "entrySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}, "additionalProperties": false}},
      "expected": {"type": "object", "required": ["daemonVersion", "webStatusMinimum"], "properties": {"daemonVersion": {"const": "0.14.1"}, "webStatusMinimum": {"const": 200}}, "additionalProperties": false}
    }, "additionalProperties": false}
  },
  "additionalProperties": false
}
