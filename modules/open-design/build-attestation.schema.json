{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "open-design-build-attestation-v1",
  "type": "object",
  "required": ["schemaVersion", "sourceCommit", "createdAt", "patch", "toolchain", "host", "environment", "inputs", "commands", "build", "native", "smoke"],
  "properties": {
    "schemaVersion": {"const": 1},
    "sourceCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "createdAt": {"type": "string", "minLength": 20, "maxLength": 64},
    "patch": {"type": "object", "required": ["path", "sha256", "postimageSha256", "changedPaths"], "properties": {
      "path": {"type": "string", "minLength": 1, "maxLength": 256},
      "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "postimageSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "changedPaths": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"const": "package.json"}}
    }, "additionalProperties": false},
    "toolchain": {"type": "object", "required": ["nodeVersion", "nodeAbi", "platform", "arch", "nodeExecutableSha256", "pnpmVersion", "pnpmExecutableSha256"], "properties": {
      "nodeVersion": {"const": "24.14.1"}, "nodeAbi": {"const": "137"}, "platform": {"const": "darwin"}, "arch": {"const": "arm64"},
      "nodeExecutableSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "pnpmVersion": {"const": "10.33.2"}, "pnpmExecutableSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    }, "additionalProperties": false},
    "host": {"type": "object", "required": ["platform", "arch", "release", "type"], "properties": {
      "platform": {"const": "darwin"}, "arch": {"const": "arm64"}, "release": {"type": "string", "minLength": 1, "maxLength": 256}, "type": {"type": "string", "minLength": 1, "maxLength": 64}
    }, "additionalProperties": false},
    "environment": {"type": "object", "required": ["CI", "COREPACK_ENABLE_DOWNLOAD_PROMPT", "HOME", "OD_WEB_OUTPUT_MODE", "PATH", "TMPDIR", "XDG_CACHE_HOME", "npm_config_cache", "npm_config_store_dir", "npm_config_update_notifier"], "properties": {
      "CI": {"const": "1"}, "COREPACK_ENABLE_DOWNLOAD_PROMPT": {"const": "0"}, "HOME": {"type": "string", "minLength": 1, "maxLength": 4096},
      "OD_WEB_OUTPUT_MODE": {"const": "standalone"}, "PATH": {"type": "string", "minLength": 1, "maxLength": 4096}, "TMPDIR": {"type": "string", "minLength": 1, "maxLength": 4096},
      "XDG_CACHE_HOME": {"type": "string", "minLength": 1, "maxLength": 4096}, "npm_config_cache": {"type": "string", "minLength": 1, "maxLength": 4096},
      "npm_config_store_dir": {"type": "string", "minLength": 1, "maxLength": 4096}, "npm_config_update_notifier": {"const": "false"}
    }, "additionalProperties": false},
    "inputs": {"type": "array", "minItems": 8, "maxItems": 64, "items": {"type": "object", "required": ["name", "sha256"], "properties": {
      "name": {"type": "string", "minLength": 1, "maxLength": 256}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    }, "additionalProperties": false}},
    "commands": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"type": "object", "required": ["ordinal", "executable", "executableSha256", "args", "cwdRole", "environmentSha256", "startedAt", "finishedAt"], "properties": {
      "ordinal": {"type": "integer", "minimum": 0}, "executable": {"type": "string", "minLength": 1, "maxLength": 4096}, "executableSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "args": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"type": "string", "maxLength": 4096}}, "cwdRole": {"const": "private-detached-checkout"},
      "environmentSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "startedAt": {"type": "string", "minLength": 20, "maxLength": 64}, "finishedAt": {"type": "string", "minLength": 20, "maxLength": 64}
    }, "additionalProperties": false}},
    "build": {"type": "object", "required": ["startedAt", "finishedAt", "privateDetachedCheckout", "postBuildVerified", "freshOutputs"], "properties": {
      "startedAt": {"type": "string", "minLength": 20, "maxLength": 64}, "finishedAt": {"type": "string", "minLength": 20, "maxLength": 64},
      "privateDetachedCheckout": {"const": true}, "postBuildVerified": {"const": true}, "freshOutputs": {"type": "array", "minItems": 4, "maxItems": 16, "items": {"type": "string", "minLength": 1, "maxLength": 256}}
    }, "additionalProperties": false},
    "native": {"type": "array", "maxItems": 10000, "items": {"type": "object", "required": ["packageName", "path", "format", "platform", "arch", "nodeAbi", "libc", "binaryFormat", "sha256", "sourceCtime", "freshFromBuild", "load"], "properties": {
      "packageName": {"enum": ["better-sqlite3", "node-pty", "sharp"]}, "path": {"type": "string", "minLength": 1, "maxLength": 1024}, "format": {"type": "string", "minLength": 1, "maxLength": 32},
      "platform": {"const": "darwin"}, "arch": {"const": "arm64"}, "nodeAbi": {"const": "137"}, "libc": {"const": "none"}, "binaryFormat": {"const": "mach-o"},
      "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "sourceCtime": {"type": "string", "minLength": 20, "maxLength": 64}, "freshFromBuild": {"const": true},
      "load": {"type": ["object", "null"], "required": ["ok", "nodeVersion", "nodeAbi", "platform", "arch"], "properties": {"ok": {"const": true}, "nodeVersion": {"const": "v24.14.1"}, "nodeAbi": {"const": "137"}, "platform": {"const": "darwin"}, "arch": {"const": "arm64"}}, "additionalProperties": false}
    }, "additionalProperties": false}},
    "smoke": {"type": "object", "required": ["ok", "namespace", "tokenSha256", "daemon", "web", "functional"], "properties": {
      "ok": {"const": true}, "namespace": {"type": "string", "minLength": 1, "maxLength": 128}, "tokenSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "daemon": {"type": "object"}, "web": {"type": "object"}, "functional": {"type": "object"}
    }, "additionalProperties": false}
  },
  "additionalProperties": false
}
