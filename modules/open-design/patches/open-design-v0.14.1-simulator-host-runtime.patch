diff --git a/apps/web/src/providers/simulator-host-mode.js b/apps/web/src/providers/simulator-host-mode.js
new file mode 100644
index 0000000000000000000000000000000000000000..d355ea1dd21af8c67be2d17b64db54aba43e1df6
--- /dev/null
+++ b/apps/web/src/providers/simulator-host-mode.js
@@ -0,0 +1,28 @@
+export const SIMULATOR_HOST_AGENT_ID = 'simulator-host-runtime';
+
+export function createSimulatorHostNetworkPolicy(fetchImpl = globalThis.fetch) {
+  /** @type {Promise<boolean> | null} */
+  let modePromise = null;
+
+  const isSimulatorHostRuntimeMode = async () => {
+    if (!modePromise) {
+      modePromise = fetchImpl('/api/agents', { cache: 'no-store' })
+        .then(async (response) => {
+          if (!response.ok) return true;
+          const body = await response.json();
+          return Array.isArray(body?.agents)
+            && body.agents.some((agent) => agent?.id === SIMULATOR_HOST_AGENT_ID);
+        })
+        .catch(() => true);
+    }
+    return modePromise;
+  };
+
+  return {
+    isSimulatorHostRuntimeMode,
+    async fetchIfAllowed(input, init) {
+      if (await isSimulatorHostRuntimeMode()) return null;
+      return fetchImpl(input, init);
+    },
+  };
+}
