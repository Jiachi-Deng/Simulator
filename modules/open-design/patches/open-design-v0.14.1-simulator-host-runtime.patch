+
+export class SimulatorHostAgentClient {
+  constructor(baseUrl, token, fetchImpl = globalThis.fetch) {
+    this.baseUrl = baseUrl;
+    this.token = token;
+    this.fetchImpl = fetchImpl;
+  }
+
+  static async fromEnvironment(env = process.env, fetchImpl = globalThis.fetch) {
+    if (typeof fetchImpl !== 'function') fail('CONFIGURATION_INVALID', 'Simulator Host Runtime configuration is invalid.');
+    const baseUrl = parseBaseUrl(env.SIMULATOR_HOST_AGENT_URL);
+    const token = await readTokenFile(env.SIMULATOR_HOST_AGENT_TOKEN_FILE);
+    return new SimulatorHostAgentClient(baseUrl, token, fetchImpl);
+  }
+
+  async request(method, pathname, body, { signal, expectNoContent = false } = {}) {
+    const context = requestSignal(REQUEST_TIMEOUT_MS, signal);
+    try {
+      const response = await this.fetchImpl(new URL(pathname, this.baseUrl), {
+        method,
+        signal: context.signal,
+        headers: {
+          authorization: `Bearer ${this.token}`,
+          ...(body === undefined ? {} : { 'content-type': 'application/json' }),
+        },
+        ...(body === undefined ? {} : { body: JSON.stringify(body) }),
+      });
+      if (expectNoContent) {
+        if (response.status !== 204) fail('HTTP_ERROR', 'Simulator Host Runtime rejected the request.');
+        return undefined;
+      }
+      if (!response.ok || response.headers.get('content-type')?.split(';', 1)[0] !== 'application/json') {
+        fail('HTTP_ERROR', 'Simulator Host Runtime rejected the request.');
+      }
+      return parseJson(await readBoundedText(response, MAX_JSON_BYTES));
+    } catch (error) {
+      if (error instanceof SimulatorHostAgentError) throw error;
+      if (signal?.aborted) fail('REQUEST_ABORTED', 'Simulator Host Runtime request was cancelled.');
+      fail(context.timedOut() ? 'REQUEST_TIMEOUT' : 'REQUEST_FAILED', 'Simulator Host Runtime is unavailable.');
+    } finally {
+      context.cleanup();
+    }
+  }
+
+  async capabilities(options) {
+    const value = await this.request('GET', '/v1/capabilities', undefined, options);
+    if (!validateCapabilities(value)) fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an invalid response.');
+    return value;
+  }
+
+  async createSession(workingDirectory, options) {
+    const body = {
+      contractVersion: CONTRACT_VERSION,
+      ...(workingDirectory ? { workingDirectory } : {}),
+    };
+    const value = await this.request('POST', '/v1/module-sessions', body, options);
+    if (!validateSession(value)) fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an invalid response.');
+    return value;
+  }
+
+  async createTurn(sessionHandle, prompt, options) {
+    const value = await this.request(
+      'POST',
+      `/v1/module-sessions/${encodeURIComponent(sessionHandle)}/turns`,
+      { contractVersion: CONTRACT_VERSION, prompt },
+      options,
+    );
+    if (!validateTurn(value, sessionHandle)) fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an invalid response.');
+    return value;
+  }
+
+  async cancel(sessionHandle, options) {
+    const value = await this.request(
+      'POST',
+      `/v1/module-sessions/${encodeURIComponent(sessionHandle)}/cancel`,
+      { contractVersion: CONTRACT_VERSION },
+      options,
+    );
+    if (!validateCancel(value)) fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an invalid response.');
+    return value;
+  }
+
+  async close(sessionHandle, options) {
+    await this.request(
+      'DELETE',
+      `/v1/module-sessions/${encodeURIComponent(sessionHandle)}`,
+      undefined,
+      { ...options, expectNoContent: true },
+    );
+  }
+
+  async stream(sessionHandle, turnId, afterSequence, signal, onEvent) {
+    const context = requestSignal(STREAM_TIMEOUT_MS, signal);
+    let response;
+    try {
+      const url = new URL(`/v1/module-sessions/${encodeURIComponent(sessionHandle)}/events`, this.baseUrl);
+      url.searchParams.set('afterSequence', String(afterSequence));
+      response = await this.fetchImpl(url, {
+        method: 'GET',
+        signal: context.signal,
+        headers: {
+          accept: 'text/event-stream',
+          authorization: `Bearer ${this.token}`,
+        },
+      });
+      if (!response.ok || response.headers.get('content-type')?.split(';', 1)[0] !== 'text/event-stream' || !response.body) {
+        fail('HTTP_ERROR', 'Simulator Host Runtime rejected the event stream.');
+      }
+      const reader = response.body.getReader();
+      const decoder = new TextDecoder('utf-8', { fatal: true });
+      let buffer = '';
+      let lastSequence = afterSequence;
+      let eventCount = 0;
+      let stopped = false;
+      try {
+        while (!stopped) {
+          const next = await reader.read();
+          if (next.done) break;
+          buffer += decoder.decode(next.value, { stream: true });
+          if (Buffer.byteLength(buffer, 'utf8') > MAX_SSE_BUFFER_BYTES) {
+            fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an invalid event stream.');
+          }
+          while (buffer.includes('\n\n')) {
+            const boundary = buffer.indexOf('\n\n');
+            const frame = buffer.slice(0, boundary).replaceAll('\r\n', '\n');
+            buffer = buffer.slice(boundary + 2);
+            if (frame === ': keepalive') continue;
+            const lines = frame.split('\n');
+            if (lines.length !== 3 || lines[0] !== `event: ${SIMULATOR_HOST_AGENT_EVENT}` || !lines[1].startsWith('id: ') || !lines[2].startsWith('data: ')) {
+              fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an invalid event stream.');
+            }
+            const id = lines[1].slice(4);
+            if (!/^(?:0|[1-9]\d*)$/u.test(id)) fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an invalid event stream.');
+            const event = parseJson(lines[2].slice(6));
+            if (!validateEvent(event, sessionHandle, turnId, lastSequence) || String(event.sequence) !== id) {
+              fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an invalid event stream.');
+            }
+            lastSequence = event.sequence;
+            eventCount += 1;
+            if (eventCount > 10_000) fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned too many events.');
