+// @ts-nocheck
+
+import { constants as fsConstants } from 'node:fs';
+import { lstat, open } from 'node:fs/promises';
+import path from 'node:path';
+
+export const SIMULATOR_HOST_AGENT_ID = 'simulator-host-runtime';
+export const SIMULATOR_HOST_AGENT_EVENT = 'module-agent.event';
+const CONTRACT_VERSION = 1;
+const TOKEN_BYTES = 64;
+const MAX_JSON_BYTES = 256 * 1024;
+const MAX_SSE_BUFFER_BYTES = 2 * 1024 * 1024;
+const MAX_PROMPT_BYTES = 2 * 1024 * 1024;
+const REQUEST_TIMEOUT_MS = 30_000;
+const STREAM_TIMEOUT_MS = 10 * 60_000;
+const hostLaunchEnvironment = Object.freeze({
+  SIMULATOR_HOST_AGENT_URL: process.env.SIMULATOR_HOST_AGENT_URL,
+  SIMULATOR_HOST_AGENT_TOKEN_FILE: process.env.SIMULATOR_HOST_AGENT_TOKEN_FILE,
+});
+delete process.env.SIMULATOR_HOST_AGENT_URL;
+delete process.env.SIMULATOR_HOST_AGENT_TOKEN_FILE;
+const cachedSessions = new Map();
+const MAX_CACHED_SESSIONS = 4;
+let cacheClock = 0;
+let cacheAdmissionTail = Promise.resolve();
+let cacheDisposal = null;
+
+const EVENT_TYPES = new Set([
+  'session.ready',
+  'turn.started',
+  'message.delta',
+  'message.completed',
+  'activity',
+  'turn.completed',
+  'turn.failed',
+  'turn.cancelled',
+  'session.closed',
+]);
+
+export class SimulatorHostAgentError extends Error {
+  constructor(code, message) {
+    super(message);
+    this.name = 'SimulatorHostAgentError';
+    this.code = code;
+  }
+}
+
+function fail(code, message) {
+  throw new SimulatorHostAgentError(code, message);
+}
+
+export function isSimulatorHostAgentMode(env = hostLaunchEnvironment) {
+  return Boolean(env.SIMULATOR_HOST_AGENT_URL || env.SIMULATOR_HOST_AGENT_TOKEN_FILE);
+}
+
+export function simulatorHostAgentInfo(env = hostLaunchEnvironment) {
+  const configured = Boolean(
+    env.SIMULATOR_HOST_AGENT_URL?.trim()
+    && env.SIMULATOR_HOST_AGENT_TOKEN_FILE?.trim(),
+  );
+  return {
+    id: SIMULATOR_HOST_AGENT_ID,
+    name: 'Simulator Host Runtime',
+    bin: process.execPath,
+    versionArgs: ['--version'],
+    models: [{ id: 'host-selected', label: 'Simulator current Workspace connection', default: true }],
+    modelsSource: 'live',
+    available: configured,
+    path: configured ? process.execPath : null,
+    version: configured ? 'contract-v1' : null,
+    streamFormat: 'simulator-host-runtime',
+    supportsCustomModel: false,
+  };
+}
+
+function plainRecord(value) {
+  if (value === null || typeof value !== 'object' || Array.isArray(value)) return null;
+  const prototype = Object.getPrototypeOf(value);
+  return prototype === Object.prototype || prototype === null ? value : null;
+}
+
+function hasExactKeys(value, required, optional = []) {
+  const record = plainRecord(value);
+  if (!record) return false;
+  const allowed = new Set([...required, ...optional]);
+  const keys = Object.keys(record);
+  return required.every((key) => Object.hasOwn(record, key))
+    && keys.every((key) => allowed.has(key));
+}
+
+function boundedString(value, maximum) {
+  return typeof value === 'string' && value.length > 0 && value.length <= maximum;
+}
+
+function validHandle(value) {
+  return boundedString(value, 256) && /^[A-Za-z0-9._~-]+$/u.test(value);
+}
+
+function parseBaseUrl(raw) {
+  let url;
+  try {
+    url = new URL(raw);
+  } catch {
+    fail('CONFIGURATION_INVALID', 'Simulator Host Runtime configuration is invalid.');
+  }
+  if (
+    url.protocol !== 'http:'
+    || !['127.0.0.1', '[::1]'].includes(url.hostname)
+    || url.username
+    || url.password
+    || url.search
+    || url.hash
+    || url.pathname !== '/'
+  ) fail('CONFIGURATION_INVALID', 'Simulator Host Runtime configuration is invalid.');
+  return new URL(url.origin);
+}
+
+async function readTokenFile(filename) {
+  if (typeof filename !== 'string' || !path.isAbsolute(filename) || path.resolve(filename) !== filename) {
+    fail('CONFIGURATION_INVALID', 'Simulator Host Runtime configuration is invalid.');
+  }
+  let handle;
+  try {
+    const before = await lstat(filename);
+    if (
+      !before.isFile()
+      || before.isSymbolicLink()
+      || before.nlink !== 1
+      || (before.size !== TOKEN_BYTES && before.size !== TOKEN_BYTES + 1)
+      || (typeof process.getuid === 'function' && before.uid !== process.getuid())
+      || (process.platform !== 'win32' && (before.mode & 0o777) !== 0o600)
+    ) fail('AUTHENTICATION_INVALID', 'Simulator Host Runtime authentication is unavailable.');
+    handle = await open(filename, fsConstants.O_RDONLY | (fsConstants.O_NOFOLLOW ?? 0));
+    const opened = await handle.stat();
+    if (opened.dev !== before.dev || opened.ino !== before.ino || opened.size !== before.size) {
+      fail('AUTHENTICATION_INVALID', 'Simulator Host Runtime authentication is unavailable.');
+    }
+    const bytes = Buffer.alloc(TOKEN_BYTES + 1);
+    const { bytesRead } = await handle.read(bytes, 0, bytes.length, 0);
+    let tokenBytes = bytes.subarray(0, bytesRead);
+    if (tokenBytes.length === TOKEN_BYTES + 1 && tokenBytes.at(-1) === 0x0a) {
+      tokenBytes = tokenBytes.subarray(0, TOKEN_BYTES);
+    }
+    if (tokenBytes.length !== TOKEN_BYTES || !/^[0-9a-f]{64}$/u.test(tokenBytes.toString('ascii'))) {
+      bytes.fill(0);
+      fail('AUTHENTICATION_INVALID', 'Simulator Host Runtime authentication is unavailable.');
+    }
+    const token = tokenBytes.toString('ascii');
+    bytes.fill(0);
+    return token;
+  } catch (error) {
+    if (error instanceof SimulatorHostAgentError) throw error;
+    fail('AUTHENTICATION_INVALID', 'Simulator Host Runtime authentication is unavailable.');
+  } finally {
+    await handle?.close().catch(() => undefined);
+  }
+}
+
+function requestSignal(timeoutMs, externalSignal) {
+  const controller = new AbortController();
+  let timedOut = false;
+  const onAbort = () => controller.abort();
+  if (externalSignal?.aborted) controller.abort();
+  else externalSignal?.addEventListener('abort', onAbort, { once: true });
+  const timer = setTimeout(() => {
+    timedOut = true;
+    controller.abort();
+  }, timeoutMs);
+  timer.unref?.();
+  return {
+    signal: controller.signal,
+    timedOut: () => timedOut,
+    cleanup: () => {
+      clearTimeout(timer);
+      externalSignal?.removeEventListener('abort', onAbort);
+    },
+  };
+}
+
+async function readBoundedText(response, maximum) {
+  if (!response.body) fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an invalid response.');
+  const reader = response.body.getReader();
+  const chunks = [];
+  let total = 0;
+  try {
+    while (true) {
+      const next = await reader.read();
+      if (next.done) break;
+      total += next.value.byteLength;
+      if (total > maximum) fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an invalid response.');
+      chunks.push(Buffer.from(next.value));
+    }
+  } finally {
+    reader.releaseLock();
+  }
+  try {
+    return new TextDecoder('utf-8', { fatal: true }).decode(Buffer.concat(chunks, total));
+  } catch {
+    fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an invalid response.');
+  }
+}
+
+function parseJson(text) {
+  try {
+    return JSON.parse(text);
+  } catch {
+    fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an invalid response.');
+  }
+}
+
+function validateCapabilities(value) {
+  if (!hasExactKeys(value, ['contractVersion', 'capability', 'features', 'limits'])) return false;
+  if (value.contractVersion !== CONTRACT_VERSION || value.capability !== 'host-agent.use') return false;
+  if (!hasExactKeys(value.features, ['streaming', 'cancellation', 'multiTurn'])) return false;
+  if (value.features.streaming !== true || value.features.cancellation !== true || value.features.multiTurn !== true) return false;
