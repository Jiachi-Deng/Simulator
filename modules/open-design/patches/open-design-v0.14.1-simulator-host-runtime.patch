+
+function validateEvent(value, expectedSession, expectedTurn, lastSequence) {
+  if (!hasExactKeys(value, ['contractVersion', 'sequence', 'sessionHandle', 'type', 'occurredAt', 'data'], ['turnId'])) return false;
+  if (
+    value.contractVersion !== CONTRACT_VERSION
+    || !Number.isSafeInteger(value.sequence)
+    || value.sequence <= lastSequence
+    || value.sessionHandle !== expectedSession
+    || !EVENT_TYPES.has(value.type)
+    || !Number.isSafeInteger(value.occurredAt)
