diff --git a/apps/daemon/src/simulator-host-agent.ts b/apps/daemon/src/simulator-host-agent.ts
new file mode 100644
index 0000000..b457d3d
--- /dev/null
+++ b/apps/daemon/src/simulator-host-agent.ts
@@ -0,0 +1,94 @@
+// @ts-nocheck
+
+import path from 'node:path';
+
+export const SIMULATOR_HOST_AGENT_ID = 'simulator-host-runtime';
+export const SIMULATOR_HOST_AGENT_CONTRACT_VERSION = '2';
+
+const HOST_ENVIRONMENT_KEYS = Object.freeze([
+  'SIMULATOR_HOST_AGENT_URL',
+  'SIMULATOR_HOST_AGENT_TOKEN_FILE',
+  'SIMULATOR_HOST_AGENT_SHIM_PATH',
+  'SIMULATOR_HOST_AGENT_CONTRACT_VERSION',
+]);
+
+const hostLaunchEnvironment = Object.freeze({
+  SIMULATOR_HOST_AGENT_URL: process.env.SIMULATOR_HOST_AGENT_URL,
+  SIMULATOR_HOST_AGENT_TOKEN_FILE: process.env.SIMULATOR_HOST_AGENT_TOKEN_FILE,
+  SIMULATOR_HOST_AGENT_SHIM_PATH: process.env.SIMULATOR_HOST_AGENT_SHIM_PATH,
+  SIMULATOR_HOST_AGENT_CONTRACT_VERSION: process.env.SIMULATOR_HOST_AGENT_CONTRACT_VERSION,
+});
+
+function nonEmpty(value) {
+  return typeof value === 'string' && value.trim().length > 0 && !value.includes('\0');
+}
+
+function isCanonicalAbsolutePath(value) {
+  return nonEmpty(value) && path.isAbsolute(value) && path.resolve(value) === value;
+}
+
+function isLoopbackBaseUrl(value) {
+  if (!nonEmpty(value)) return false;
+  try {
+    const url = new URL(value);
+    return url.protocol === 'http:'
+      && (url.hostname === '127.0.0.1' || url.hostname === '[::1]')
+      && !url.username
+      && !url.password
+      && !url.search
+      && !url.hash
+      && url.pathname === '/';
+  } catch {
+    return false;
+  }
+}
+
+export function isSimulatorHostAgentMode(
+  env = hostLaunchEnvironment,
+) {
+  // A partial Host grant is still Host mode. Fail closed instead of exposing
+  // OpenDesign Cloud or a locally installed provider CLI as a fallback. An
+  // explicitly present empty value is partial configuration too.
+  return HOST_ENVIRONMENT_KEYS.some((key) => typeof env[key] === 'string');
+}
+
+export function simulatorHostAgentConfigured(
+  env = hostLaunchEnvironment,
+) {
+  return isLoopbackBaseUrl(env.SIMULATOR_HOST_AGENT_URL)
+    && isCanonicalAbsolutePath(env.SIMULATOR_HOST_AGENT_TOKEN_FILE)
+    && isCanonicalAbsolutePath(env.SIMULATOR_HOST_AGENT_SHIM_PATH)
+    && env.SIMULATOR_HOST_AGENT_CONTRACT_VERSION === SIMULATOR_HOST_AGENT_CONTRACT_VERSION;
+}
+
+export function simulatorHostAgentLaunchEnvironment(
+  env = hostLaunchEnvironment,
+) {
+  if (!simulatorHostAgentConfigured(env)) return Object.freeze({});
+  return Object.freeze({
+    SIMULATOR_HOST_AGENT_URL: env.SIMULATOR_HOST_AGENT_URL,
+    SIMULATOR_HOST_AGENT_TOKEN_FILE: env.SIMULATOR_HOST_AGENT_TOKEN_FILE,
+    SIMULATOR_HOST_AGENT_SHIM_PATH: env.SIMULATOR_HOST_AGENT_SHIM_PATH,
+    SIMULATOR_HOST_AGENT_CONTRACT_VERSION: SIMULATOR_HOST_AGENT_CONTRACT_VERSION,
+  });
+}
+
+export function simulatorHostAgentInfo(
+  env = hostLaunchEnvironment,
+) {
+  const configured = simulatorHostAgentConfigured(env);
+  const shimPath = configured ? env.SIMULATOR_HOST_AGENT_SHIM_PATH : null;
+  return {
+    id: SIMULATOR_HOST_AGENT_ID,
+    name: 'Simulator Host Runtime',
+    bin: shimPath ?? 'simulator-host-agent-unconfigured',
+    versionArgs: ['--version'],
+    models: [{ id: 'host-selected', label: 'Simulator current Workspace connection', default: true }],
+    modelsSource: 'live',
+    available: configured,
+    path: shimPath,
+    version: configured ? 'contract-v2' : null,
+    streamFormat: 'json-event-stream',
+    supportsCustomModel: false,
+  };
+}
