diff --git a/apps/web/src/providers/simulator-host-mode.js b/apps/web/src/providers/simulator-host-mode.js
new file mode 100644
index 0000000..81a9259
--- /dev/null
+++ b/apps/web/src/providers/simulator-host-mode.js
@@ -0,0 +1,54 @@
+export const SIMULATOR_HOST_AGENT_ID = 'simulator-host-runtime';
+export const SIMULATOR_HOST_RUNTIME_LABEL = 'Simulator Host Runtime';
+export const SIMULATOR_HOST_RUNTIME_DESCRIPTION = '使用 Simulator 当前 Workspace 连接';
+
+export function isSimulatorHostAgentConfig(config) {
+  return config?.mode === 'daemon' && config?.agentId === SIMULATOR_HOST_AGENT_ID;
+}
+
+export function normalizeSimulatorHostConfig(config) {
+  return {
+    ...config,
+    mode: 'daemon',
+    apiKey: '',
+    apiProtocolConfigs: {},
+    byokProviderConfigDrafts: {},
+    mediaProviders: {},
+    agentId: SIMULATOR_HOST_AGENT_ID,
+    agentModels: {},
+    agentCliEnv: {},
+    agentCliEnvIntent: {},
+    onboardingCompleted: true,
+    telemetry: { metrics: false, content: false },
+  };
+}
+
+export function createSimulatorHostNetworkPolicy(fetchImpl) {
+  /** @type {Promise<boolean> | null} */
+  let modePromise = null;
+
+  const isSimulatorHostRuntimeMode = async () => {
+    if (!modePromise) {
+      // Resolve the global fetch lazily. The browser installs it before app
+      // bootstrap, while tests replace it after importing this module.
+      const activeFetch = fetchImpl ?? globalThis.fetch;
+      modePromise = activeFetch('/api/agents', { cache: 'no-store' })
+        .then(async (response) => {
+          if (!response.ok) return true;
+          const body = await response.json();
+          return Array.isArray(body?.agents)
+            && body.agents.some((agent) => agent?.id === SIMULATOR_HOST_AGENT_ID);
+        })
+        .catch(() => true);
+    }
+    return modePromise;
+  };
+
+  return {
+    isSimulatorHostRuntimeMode,
+    async fetchIfAllowed(input, init) {
+      if (await isSimulatorHostRuntimeMode()) return null;
+      return (fetchImpl ?? globalThis.fetch)(input, init);
+    },
+  };
+}
diff --git a/apps/web/src/styles/simulator-host.css b/apps/web/src/styles/simulator-host.css
new file mode 100644
index 0000000..61e60d6
--- /dev/null
+++ b/apps/web/src/styles/simulator-host.css
@@ -0,0 +1,39 @@
+.simulator-host-runtime-chip {
+  cursor: default;
+}
+
+.simulator-host-runtime-dot {
+  width: 7px;
+  height: 7px;
+  flex: 0 0 7px;
+  border-radius: 999px;
+  background: var(--text-tertiary);
+  box-shadow: 0 0 0 2px color-mix(in srgb, var(--text-tertiary) 16%, transparent);
+}
+
+.simulator-host-runtime-dot.is-ready {
+  background: #36a269;
+  box-shadow: 0 0 0 2px color-mix(in srgb, #36a269 18%, transparent);
+}
+
+.simulator-host-runtime-avatar {
+  cursor: default;
+}
+
+.simulator-host-settings-status {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  margin-bottom: 8px;
+}
+
+/* Simulator's embedded WebContentsView deliberately denies downloads. Keep
+   preview/edit/version-history intact while removing controls that cannot
+   complete in this security boundary. */
+html[data-simulator-host-runtime='true'] .chrome-file-action-menus,
+html[data-simulator-host-runtime='true'] .markdown-workbench .chrome-share-menu,
+html[data-simulator-host-runtime='true'] .df-preview-download,
+html[data-simulator-host-runtime='true'] .df-batch-actions > button:first-child,
+html[data-simulator-host-runtime='true'] a[download] {
+  display: none !important;
+}
