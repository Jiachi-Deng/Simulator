diff --git a/apps/daemon/src/runtimes/simulator-host-v2-event-stream.ts b/apps/daemon/src/runtimes/simulator-host-v2-event-stream.ts
new file mode 100644
index 0000000..ae98650
--- /dev/null
+++ b/apps/daemon/src/runtimes/simulator-host-v2-event-stream.ts
@@ -0,0 +1,291 @@
+// @ts-nocheck
+
+const MAX_EVENT_BYTES = 256 * 1024;
+const MAX_DELTA_BYTES = 64 * 1024;
+const MAX_ACTIVITY_LABEL_BYTES = 4096;
+const RUN_HANDLE = /^run_[0-9a-f]{32}$/u;
+const ITEM_ID = /^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$/u;
+const MEDIA_TYPE = /^[A-Za-z0-9!#$&^_.+-]+\/[A-Za-z0-9!#$&^_.+-]+$/u;
+
+const EVENT_TYPES = new Set([
+  'run.accepted',
+  'turn.started',
+  'message.delta',
+  'reasoning.delta',
+  'activity',
+  'presentation.item',
+  'turn.completed',
+  'turn.failed',
+  'turn.interrupted',
+  'run.closed',
+]);
+
+const FAILURE_RETRYABILITY = Object.freeze({
+  RUNTIME_UNAVAILABLE: true,
+  TOOL_BOUNDARY_UNAVAILABLE: false,
+  RUN_TIMEOUT: true,
+  BROKER_DISCONNECTED: true,
+  INTERNAL_ERROR: false,
+});
+
+const INTERRUPTION_RETRYABILITY = Object.freeze({
+  CLIENT_CANCELLED: false,
+  CRAFT_TURN_PREEMPTED: true,
+  BROKER_DISCONNECTED: true,
+  RUN_TIMEOUT: true,
+  HOST_SHUTDOWN: true,
+});
+
+function isRecord(value) {
+  return value !== null && typeof value === 'object' && !Array.isArray(value);
+}
+
+function exactKeys(value, required, optional = []) {
+  if (!isRecord(value)) return false;
+  const allowed = new Set([...required, ...optional]);
+  return required.every((key) => Object.hasOwn(value, key))
+    && Object.keys(value).every((key) => allowed.has(key));
+}
+
+function utf8Bytes(value) {
+  return Buffer.byteLength(value, 'utf8');
+}
+
+function boundedString(value, { minBytes = 0, maxBytes, rejectNul = false }) {
+  if (typeof value !== 'string') return false;
+  const bytes = utf8Bytes(value);
+  return bytes >= minBytes
+    && bytes <= maxBytes
+    && (!rejectNul || !value.includes('\0'));
+}
+
+function terminalRetryability(code) {
+  if (Object.hasOwn(FAILURE_RETRYABILITY, code)) return FAILURE_RETRYABILITY[code];
+  if (Object.hasOwn(INTERRUPTION_RETRYABILITY, code)) return INTERRUPTION_RETRYABILITY[code];
+  return undefined;
+}
+
+// This is the narrow bridge used by the daemon's shared sendAgentEvent choke
+// point. It accepts only terminal errors produced by this strict parser and
+// returns the existing SSE error envelope without collapsing the Host's
+// canonical code/reason or retryability into AGENT_EXECUTION_FAILED.
+export function simulatorHostV2TerminalSsePayload(parserKind, event) {
+  if (
+    parserKind !== 'simulator-host-v2'
+    || !exactKeys(event, ['type', 'message', 'code', 'retryable'], ['raw'])
+    || event.type !== 'error'
+    || !boundedString(event.message, { minBytes: 1, maxBytes: MAX_EVENT_BYTES, rejectNul: true })
+  ) return null;
+  const retryable = terminalRetryability(event.code);
+  if (retryable === undefined || event.retryable !== retryable) return null;
+  if (event.raw !== undefined && !boundedString(event.raw, {
+    minBytes: 1,
+    maxBytes: MAX_EVENT_BYTES,
+    rejectNul: true,
+  })) return null;
+  return {
+    message: event.message,
+    error: {
+      code: event.code,
+      message: event.message,
+      retryable,
+      ...(event.raw === undefined ? {} : { details: { raw: event.raw } }),
+    },
+  };
+}
+
+export function simulatorHostV2AgentEventIsSubstantive(parserKind, event) {
+  return parserKind === 'simulator-host-v2'
+    && isRecord(event)
+    && event.type === 'status'
+    && event.simulatorHostV2Completion === 'presentation'
+    && isRecord(event.presentation);
+}
+
+export function createSimulatorHostV2EventHandler(onEvent) {
+  const state = {
+    runHandle: null,
+    lastSequence: 0,
+    phase: 'initial',
+    textSoFar: '',
+    textBytes: 0,
+    textOverflowed: false,
+    protocolFailed: false,
+  };
+
+  const protocolError = (message) => {
+    if (!state.protocolFailed) {
+      state.protocolFailed = true;
+      onEvent({
+        type: 'error',
+        message: `Simulator Host Runtime protocol error: ${message}`,
+      });
+    }
+    return true;
+  };
+
+  const validateEnvelope = (obj) => {
+    if (!exactKeys(obj, [
+      'contractVersion',
+      'eventId',
+      'sequence',
+      'runHandle',
+      'occurredAt',
+      'type',
+      'data',
+    ])) return 'event contains missing or unknown fields';
+    let encoded;
+    try {
+      encoded = JSON.stringify(obj);
+    } catch {
+      return 'event is not JSON serializable';
+    }
+    if (utf8Bytes(encoded) > MAX_EVENT_BYTES) return 'event exceeds the byte limit';
+    if (obj.contractVersion !== 2) return 'contractVersion must be 2';
+    if (!Number.isSafeInteger(obj.sequence) || obj.sequence < 1) return 'sequence is invalid';
+    if (obj.eventId !== String(obj.sequence)) return 'eventId does not match sequence';
+    if (obj.sequence !== state.lastSequence + 1) return 'event sequence is not contiguous';
+    if (typeof obj.runHandle !== 'string' || !RUN_HANDLE.test(obj.runHandle)) return 'runHandle is invalid';
+    if (state.runHandle !== null && state.runHandle !== obj.runHandle) return 'runHandle changed';
+    if (!Number.isSafeInteger(obj.occurredAt) || obj.occurredAt < 0) return 'occurredAt is invalid';
+    if (typeof obj.type !== 'string' || !EVENT_TYPES.has(obj.type)) return 'event type is invalid';
+    if (!isRecord(obj.data)) return 'event data is invalid';
+    return null;
+  };
+
+  const handle = (obj) => {
+    if (state.protocolFailed) return true;
+    if (!isRecord(obj)) return protocolError('JSONL frame must be an object');
+    const envelopeError = validateEnvelope(obj);
+    if (envelopeError) return protocolError(envelopeError);
+
+    const { type, data } = obj;
+    if (type === 'run.accepted') {
+      if (state.phase !== 'initial' || !exactKeys(data, [])) return protocolError('run.accepted is out of order');
+      state.phase = 'awaiting-started';
+      onEvent({ type: 'status', label: 'initializing' });
+    } else if (type === 'turn.started') {
+      if (state.phase !== 'awaiting-started' || !exactKeys(data, [])) return protocolError('turn.started is out of order');
+      state.phase = 'running';
+      onEvent({ type: 'status', label: 'running' });
+    } else if (type === 'message.delta') {
+      if (
+        state.phase !== 'running'
+        || !exactKeys(data, ['delta'])
+        || !boundedString(data.delta, { minBytes: 1, maxBytes: MAX_DELTA_BYTES, rejectNul: true })
+      ) return protocolError('message.delta is invalid or out of order');
+      if (!state.textOverflowed) {
+        const deltaBytes = utf8Bytes(data.delta);
+        if (state.textBytes + deltaBytes > MAX_EVENT_BYTES) {
+          state.textOverflowed = true;
+          state.textSoFar = '';
+          state.textBytes = 0;
+        } else {
+          state.textSoFar += data.delta;
+          state.textBytes += deltaBytes;
+        }
+      }
+      onEvent({ type: 'text_delta', delta: data.delta });
+    } else if (type === 'reasoning.delta') {
+      if (
+        state.phase !== 'running'
+        || !exactKeys(data, ['delta'])
+        || !boundedString(data.delta, { minBytes: 1, maxBytes: MAX_DELTA_BYTES, rejectNul: true })
+      ) return protocolError('reasoning.delta is invalid or out of order');
+      onEvent({ type: 'thinking_delta', delta: data.delta });
+    } else if (type === 'activity') {
+      if (
+        state.phase !== 'running'
+        || !exactKeys(data, ['phase', 'kind'], ['label'])
+        || !['started', 'finished'].includes(data.phase)
+        || !['runtime', 'tool'].includes(data.kind)
+        || (data.label !== undefined && !boundedString(data.label, {
+          minBytes: 1,
+          maxBytes: MAX_ACTIVITY_LABEL_BYTES,
+          rejectNul: true,
+        }))
+      ) return protocolError('activity is invalid or out of order');
+      onEvent({
+        type: 'status',
+        label: typeof data.label === 'string' ? data.label : `${data.kind} ${data.phase}`,
+      });
+    } else if (type === 'presentation.item') {
+      if (
+        state.phase !== 'running'
+        || !exactKeys(data, ['itemId', 'kind'], ['title', 'text', 'uri', 'mediaType'])
+        || typeof data.itemId !== 'string'
+        || !ITEM_ID.test(data.itemId)
+        || !['text', 'image', 'file', 'preview'].includes(data.kind)
+        || (data.title !== undefined && !boundedString(data.title, { minBytes: 1, maxBytes: 4096, rejectNul: true }))
+        || (data.text !== undefined && !boundedString(data.text, { minBytes: 1, maxBytes: MAX_EVENT_BYTES, rejectNul: true }))
+        || (data.uri !== undefined && !boundedString(data.uri, { minBytes: 1, maxBytes: 8192, rejectNul: true }))
+        || (data.mediaType !== undefined && !boundedString(data.mediaType, { minBytes: 1, maxBytes: 256, rejectNul: true }))
+        || (data.mediaType !== undefined && !MEDIA_TYPE.test(data.mediaType))
+      ) return protocolError('presentation.item is invalid or out of order');
+      onEvent({
+        type: 'status',
+        label: typeof data.title === 'string' ? data.title : `${data.kind}: ${data.itemId}`,
+        presentation: { ...data },
+        simulatorHostV2Completion: 'presentation',
+      });
+    } else if (type === 'turn.completed') {
+      if (
+        state.phase !== 'running'
+        || !exactKeys(data, [], ['finalText'])
+        || (data.finalText !== undefined && !boundedString(data.finalText, {
+          maxBytes: MAX_EVENT_BYTES,
+          rejectNul: true,
+        }))
+      ) return protocolError('turn.completed is invalid or out of order');
+      if (typeof data.finalText === 'string') {
+        if (state.textOverflowed) return protocolError('finalText cannot be verified after streamed text exceeds the byte limit');
+        if (!data.finalText.startsWith(state.textSoFar)) return protocolError('finalText disagrees with message deltas');
+        const suffix = data.finalText.slice(state.textSoFar.length);
+        if (suffix) onEvent({ type: 'text_delta', delta: suffix });
+        state.textSoFar = data.finalText;
+        state.textBytes = utf8Bytes(data.finalText);
+      }
+      state.phase = 'terminal';
+      onEvent({ type: 'status', label: 'completed' });
+    } else if (type === 'turn.failed') {
+      if (
+        !['awaiting-started', 'running'].includes(state.phase)
+        || !exactKeys(data, ['code', 'retryable'])
+        || !Object.hasOwn(FAILURE_RETRYABILITY, data.code)
+        || data.retryable !== FAILURE_RETRYABILITY[data.code]
+      ) return protocolError('turn.failed is invalid or out of order');
+      state.phase = 'terminal';
+      onEvent({
+        type: 'error',
+        message: `Simulator Host Runtime failed: ${data.code}`,
+        code: data.code,
+        retryable: data.retryable,
+        raw: JSON.stringify(obj),
+      });
+    } else if (type === 'turn.interrupted') {
+      if (
+        !['awaiting-started', 'running'].includes(state.phase)
+        || !exactKeys(data, ['reason', 'retryable'])
+        || !Object.hasOwn(INTERRUPTION_RETRYABILITY, data.reason)
+        || data.retryable !== INTERRUPTION_RETRYABILITY[data.reason]
+      ) return protocolError('turn.interrupted is invalid or out of order');
+      state.phase = 'terminal';
+      onEvent({
+        type: 'error',
+        message: `Simulator Host Runtime interrupted: ${data.reason}`,
+        code: data.reason,
+        retryable: data.retryable,
+        raw: JSON.stringify(obj),
+      });
+    } else if (type === 'run.closed') {
+      if (state.phase !== 'terminal' || !exactKeys(data, [])) return protocolError('run.closed is out of order');
+      state.phase = 'closed';
+      onEvent({ type: 'status', label: 'closed' });
+    }
+
+    state.runHandle ??= obj.runHandle;
+    state.lastSequence = obj.sequence;
+    return true;
+  };
+
+  return {
+    handle,
+    handleInvalidJson: () => protocolError('stdout line is not valid JSON'),
+    handleEnd: () => state.protocolFailed
+      || state.phase === 'closed'
+      || protocolError('stdout ended before run.closed'),
+  };
+}
