+        if (stopped) await reader.cancel().catch(() => undefined);
+        reader.releaseLock();
+      }
+      return { lastSequence, terminal: stopped };
+    } catch (error) {
+      if (error instanceof SimulatorHostAgentError) throw error;
+      if (signal?.aborted) fail('REQUEST_ABORTED', 'Simulator Host Runtime request was cancelled.');
+      fail(context.timedOut() ? 'REQUEST_TIMEOUT' : 'REQUEST_FAILED', 'Simulator Host Runtime is unavailable.');
+    } finally {
+      context.cleanup();
+    }
+  }
+}
+
+function appendCompletedText(completedText, streamedText, send) {
+  if (completedText === streamedText) return streamedText;
+  if (!completedText.startsWith(streamedText)) {
+    fail('PROTOCOL_INVALID', 'Simulator Host Runtime returned an inconsistent transcript.');
+  }
+  const suffix = completedText.slice(streamedText.length);
+  if (suffix) send('agent', { type: 'text_delta', delta: suffix });
+  return completedText;
+}
+
+export async function runSimulatorHostAgentTurn({ prompt, workingDirectory, run, send, finish, env = process.env, fetchImpl = globalThis.fetch }) {
+  if (typeof prompt !== 'string' || Buffer.byteLength(prompt, 'utf8') > MAX_PROMPT_BYTES) {
+    fail('INPUT_INVALID', 'Simulator Host Runtime prompt is invalid.');
+  }
+  const client = await SimulatorHostAgentClient.fromEnvironment(env, fetchImpl);
+  const lifecycleAbort = new AbortController();
+  let session;
+  let turn;
+  let terminal = null;
+  let cancelPromise = null;
+  let streamedText = '';
+  let lastSequence = 0;
+
+  const throwIfCancelled = () => {
+    if (!run.cancelRequested && !lifecycleAbort.signal.aborted) return;
+    lifecycleAbort.abort();
+    fail('REQUEST_ABORTED', 'Simulator Host Runtime request was cancelled.');
+  };
+  const cancelHostSession = () => {
+    lifecycleAbort.abort();
+    if (!session || terminal) return Promise.resolve();
+    if (!cancelPromise) cancelPromise = client.cancel(session.sessionHandle);
+    return cancelPromise;
+  };
+
+  // Install cancellation before the first Host request. This closes the race
+  // where Open Design could mark a queued run canceled while capabilities,
+  // session creation, or turn creation continued in the Host Runtime.
+  run.externalCancel = cancelHostSession;
+
+  try {
+    throwIfCancelled();
+    const capabilities = await client.capabilities({ signal: lifecycleAbort.signal });
+    throwIfCancelled();
+    if (Buffer.byteLength(prompt, 'utf8') > capabilities.limits.maxPromptBytes) {
+      fail('INPUT_INVALID', 'Simulator Host Runtime prompt exceeds the Host limit.');
+    }
+    session = await client.createSession(workingDirectory, { signal: lifecycleAbort.signal });
+    throwIfCancelled();
+    turn = await client.createTurn(session.sessionHandle, prompt, { signal: lifecycleAbort.signal });
+    throwIfCancelled();
+    run.status = 'running';
+    run.updatedAt = Date.now();
+    send('start', {
+      runId: run.id,
+      agentId: SIMULATOR_HOST_AGENT_ID,
+      bin: 'Simulator Host Runtime',
+      streamFormat: 'simulator-host-runtime',
+      projectId: run.projectId ?? null,
+      cwd: workingDirectory,
+      model: 'host-selected',
+      reasoning: null,
+      toolTokenExpiresAt: null,
+    });
+
+    for (let reconnect = 0; reconnect < 2 && !terminal; reconnect += 1) {
+      const result = await client.stream(
+        session.sessionHandle,
+        turn.turnId,
+        lastSequence,
+        lifecycleAbort.signal,
+        (event) => {
+          lastSequence = event.sequence;
+          if (event.type === 'message.delta') {
+            streamedText += event.data.delta;
+            if (streamedText.length > MAX_PROMPT_BYTES) fail('PROTOCOL_INVALID', 'Simulator Host Runtime transcript exceeded the limit.');
+            send('agent', { type: 'text_delta', delta: event.data.delta });
+          } else if (event.type === 'message.completed') {
+            streamedText = appendCompletedText(event.data.text, streamedText, send);
+          } else if (event.type === 'activity') {
+            send('agent', { type: 'status', label: event.data.label ?? event.data.phase ?? event.data.kind });
+          } else if (event.type === 'turn.completed') {
+            if (typeof event.data.text === 'string') streamedText = appendCompletedText(event.data.text, streamedText, send);
+            terminal = 'succeeded';
+            return false;
+          } else if (event.type === 'turn.failed') {
+            send('error', { error: { code: 'HOST_AGENT_TURN_FAILED', message: 'Simulator Host Runtime turn failed.', retryable: false, details: { hostCode: event.data.code } } });
+            terminal = 'failed';
+            return false;
+          } else if (event.type === 'turn.cancelled') {
+            terminal = 'canceled';
+            return false;
+          } else if (event.type === 'session.closed') {
+            fail('PROTOCOL_INVALID', 'Simulator Host Runtime closed the session before the turn completed.');
+          }
+          return true;
+        },
+      );
+      lastSequence = result.lastSequence;
+    }
+    if (!terminal) fail('STREAM_ENDED', 'Simulator Host Runtime event stream ended unexpectedly.');
+    if (run.cancelRequested || lifecycleAbort.signal.aborted) terminal = 'canceled';
+    if (cancelPromise) await cancelPromise.catch(() => undefined);
+    try {
+      await client.close(session.sessionHandle);
+      session = undefined;
+    } catch (error) {
+      if (terminal === 'succeeded') throw error;
+    }
+    if (terminal === 'succeeded') finish(run, 'succeeded', 0, null);
+    else if (terminal === 'failed') finish(run, 'failed', 1, null);
+    else finish(run, 'canceled', null, 'SIGTERM');
+  } catch (error) {
+    if (run.cancelRequested || lifecycleAbort.signal.aborted) return;
+    throw error;
+  } finally {
+    run.externalCancel = null;
+    lifecycleAbort.abort();
+    if (run.cancelRequested && session && !terminal && !cancelPromise) {
+      cancelPromise = client.cancel(session.sessionHandle);
+    }
+    if (cancelPromise) await cancelPromise.catch(() => undefined);
+    if (session) await client.close(session.sessionHandle).catch(() => undefined);
+  }
+}
