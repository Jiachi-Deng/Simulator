{
  "name": "@simulator/module-downloader",
  "version": "0.11.1",
  "license": "Apache-2.0",
  "description": "Verified catalog and artifact downloader for Simulator modules",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing/index.ts"
  },
  "scripts": {
    "test": "bun test src",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target node --format esm"
  },
  "dependencies": {
    "@simulator/module-contract": "workspace:*",
    "@simulator/module-release-trust": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "typescript": "^5.8.2"
  }
}
