{
  "name": "@craft-agent/server",
  "version": "0.12.0",
  "description": "Standalone headless Simulator server (Bun runtime)",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "craft-server": "src/index.ts"
  },
  "files": [
    "src/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": {
    "name": "Simulator contributors",
    "url": "https://github.com/Jiachi-Deng/Simulator"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/Jiachi-Deng/Simulator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jiachi-Deng/Simulator.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/Jiachi-Deng/Simulator/issues"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "generate-token": "bun run src/index.ts --generate-token",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@craft-agent/core": "workspace:*",
    "@craft-agent/messaging-gateway": "workspace:*",
    "@craft-agent/server-core": "workspace:*",
    "@craft-agent/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "@types/node": "^22.0.0",
    "ws": "^8.16.0"
  }
}
